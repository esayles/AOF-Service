option_settings:
  aws:elasticbeanstalk:container:python:
    WSGIPath: aof_service.wsgi:application
  aws:elasticbeanstalk:application:environment:
    DJANGO_SETTINGS_MODULE: aof_service.settings.production

container_commands:
  00_reset_schema:
    # No-op unless the environment property RESET_DB=1 is set. Used once to
    # rebuild the pre-2026 database whose migration history was incompatible
    # with the custom User model. See reset_schema.py for details.
    command: "source /var/app/venv/*/bin/activate && python manage.py reset_schema"
    leader_only: true
  01_migrate:
    command: "source /var/app/venv/*/bin/activate && python manage.py migrate --noinput"
    leader_only: true
  02_collectstatic:
    command: "source /var/app/venv/*/bin/activate && python manage.py collectstatic --noinput"
    leader_only: true
  03_createsu:
    command: "source /var/app/venv/*/bin/activate && python manage.py createsu"
    leader_only: true
    ignoreErrors: true
